{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acp.dev/schema/v1.0/sif.schema.json",
  "title": "SIF Intent — L1 structural schema v1.0",
  "description": "Generic, domain-INDEPENDENT structural (L1) validation of a SIF intent batch: shape and fields per kind only. The VALIDATING, domain-specific schema is GENERATED from the registry at runtime (enum-injected entity/action/field names); this static file does not know domain names. See docs/07-artifacts-and-schemas.md.",
  "type": "object",
  "required": ["operations"],
  "additionalProperties": false,
  "properties": {
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/operation" }
    }
  },
  "$defs": {
    "operation": {
      "type": "object",
      "required": ["kind", "entity"],
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["observe", "assess", "record", "effect", "transition"] },
        "entity": { "type": "string" },
        "action": { "type": "string" },
        "data": { "type": "object" },
        "filters": { "type": "object" },
        "resolve": { "type": "object" },
        "relations": { "type": "array", "items": { "type": "string" } },
        "sort": {},
        "limit": { "type": "integer" },
        "aggregate": {}
      }
    }
  }
}
