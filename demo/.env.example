# Copy to .env and paste a key. Anthropic (Claude) is the spec's default provider.
# The whole stack runs without a key in scripted "fake" mode (LLM_PROVIDER=fake),
# but the real demo wants a key.

ANTHROPIC_API_KEY=

# Optional: OpenAI is also supported.
OPENAI_API_KEY=

# auto  = use whichever key is present (Anthropic preferred), else the fake LLM
# fake  = no key; deterministic scripted agent (CI / offline)
# anthropic | openai = force a provider
LLM_PROVIDER=auto
